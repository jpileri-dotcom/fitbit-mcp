# Fitbit app credentials (from https://dev.fitbit.com/apps)
FITBIT_CLIENT_ID=your_fitbit_client_id
FITBIT_CLIENT_SECRET=your_fitbit_client_secret

# Public URL of this MCP server (must match Fitbit app redirect URI)
# Register {SERVER_URL}/fitbit-callback as the redirect URI in your Fitbit app
SERVER_URL=https://your-tunnel-url.example.com

# Cloudflare Tunnel token (get from Cloudflare Zero Trust dashboard)
Cloudflare_Token=your_cloudflare_tunnel_token_here

# --- Connecting Claude to this server ---
#
# Claude.ai web connectors:
#   Set the connector URL to:
#   https://<your-tunnel-url>/mcp
#   (OAuth flow will handle authentication automatically)
#
# Claude Desktop (claude_desktop_config.json):
#   {
#     "mcpServers": {
#       "fitbit": {
#         "type": "http",
#         "url": "https://<your-tunnel-url>/mcp"
#       }
#     }
#   }
